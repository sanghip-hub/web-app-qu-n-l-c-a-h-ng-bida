generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Venue {
  id         String            @id @default(cuid())
  name       String
  type       String            // "BILLIARD" | "COURT"
  hourlyRate Float
  status     String            @default("AVAILABLE") // "AVAILABLE" | "OCCUPIED" | "MAINTENANCE"
  sessions   Session[]
  createdAt  DateTime          @default(now())
}

model Session {
  id        String            @id @default(cuid())
  venueId   String
  venue     Venue             @relation(fields: [venueId], references: [id])
  startedAt DateTime          @default(now())
  endedAt   DateTime?
  order     Order?
  rentals   EquipmentRental[]
}

model Order {
  id            String      @id @default(cuid())
  sessionId     String      @unique
  session       Session     @relation(fields: [sessionId], references: [id])
  items         OrderItem[]
  paymentMethod String?     // "CASH" | "TRANSFER"
  status        String      @default("OPEN") // "OPEN" | "PAID"
  totalAmount   Float       @default(0)
  createdAt     DateTime    @default(now())
  paidAt        DateTime?
}

model OrderItem {
  id          String     @id @default(cuid())
  orderId     String
  order       Order      @relation(fields: [orderId], references: [id])
  type        String     // "TIME" | "PRODUCT" | "EQUIPMENT"
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id])
  equipmentId String?
  equipment   Equipment? @relation(fields: [equipmentId], references: [id])
  name        String
  quantity    Int        @default(1)
  unitPrice   Float
  amount      Float
}

model Product {
  id         String      @id @default(cuid())
  name       String
  category   String
  price      Float
  stock      Int?
  active     Boolean     @default(true)
  orderItems OrderItem[]
}

model Equipment {
  id          String            @id @default(cuid())
  name        String
  rentalPrice Float
  rentalUnit  String            @default("PER_USE") // "PER_USE" | "PER_HOUR"
  available   Int               @default(1)
  active      Boolean           @default(true)
  orderItems  OrderItem[]
  rentals     EquipmentRental[]
}

model EquipmentRental {
  id          String    @id @default(cuid())
  sessionId   String
  session     Session   @relation(fields: [sessionId], references: [id])
  equipmentId String
  equipment   Equipment @relation(fields: [equipmentId], references: [id])
  quantity    Int       @default(1)
  startedAt   DateTime  @default(now())
  endedAt     DateTime?
}
